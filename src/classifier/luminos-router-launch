#!/bin/bash
# Luminos .exe launcher — routes to correct layer
# [CHANGE: gemini-cli | 2026-04-25] Fixed: removed any potential prompts, auto-route to Wine for Zone 2+
EXE="$1"
if [ -z "$EXE" ]; then exit 1; fi

# Normalize path
EXE_ABS=$(readlink -f "$EXE")

# Try to classify via daemon
RESULT=$(echo "{\"type\":\"classify\",\"payload\":{\"path\":\"$EXE_ABS\"}}" | \
  socat - UNIX-CONNECT:/run/user/$(id -u)/luminos-router.sock 2>/dev/null)

if [ -z "$RESULT" ]; then
    # Fallback to local user socket if system one fails
    RESULT=$(echo "{\"type\":\"classify\",\"payload\":{\"path\":\"$EXE_ABS\"}}" | \
      socat - UNIX-CONNECT:/run/user/$(id -u)/luminos-router.sock 2>/dev/null)
fi

ZONE=$(echo $RESULT | python3 -c "import sys,json; print(json.load(sys.stdin).get('payload', {}).get('zone', 2))" 2>/dev/null || echo "2")

case $ZONE in
  1) 
    # Native Linux (unlikely for .exe but supported in theory)
    exec "$EXE_ABS" 
    ;;
  2) 
    # Zone 2: Standard Wine/Proton
    notify-send "Luminos" "Running via Wine: $(basename "$EXE_ABS")"
    exec wine "$EXE_ABS" 
    ;;
  3) 
    # Zone 3: Firecracker (Silent fallback to Wine if stubbed)
    notify-send "Luminos" "Running via Firecracker: $(basename "$EXE_ABS")"
    exec wine "$EXE_ABS" 
    ;;
  4) 
    # Zone 4: KVM (Silent fallback to Wine if stubbed)
    notify-send "Luminos" "Running via KVM: $(basename "$EXE_ABS")"
    exec wine "$EXE_ABS" 
    ;;
  *) 
    # Default: Silent fallback to Wine
    notify-send "Luminos" "Launching: $(basename "$EXE_ABS")"
    exec wine "$EXE_ABS" 
    ;;
esac
