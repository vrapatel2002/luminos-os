#!/bin/bash
# Luminos .exe launcher — routes to correct layer
# [CHANGE: gemini-cli | 2026-04-25] Fixed: removed any potential prompts, auto-route to Wine for Zone 2+
EXE="$1"
if [ -z "$EXE" ]; then exit 1; fi

# Normalize path
EXE_ABS=$(readlink -f "$EXE")

# Try to classify via daemon
RESULT=$(echo "{\"type\":\"classify\",\"payload\":{\"path\":\"$EXE_ABS\"}}" | \
  socat - UNIX-CONNECT:/run/user/$(id -u)/luminos-router.sock 2>/dev/null)

if [ -z "$RESULT" ]; then
    # Fallback to system socket
    RESULT=$(echo "{\"type\":\"classify\",\"payload\":{\"path\":\"$EXE_ABS\"}}" | \
      sudo socat - UNIX-CONNECT:/tmp/luminos-router.sock 2>/dev/null)
fi

ZONE=$(echo $RESULT | python3 -c "import sys,json; print(json.load(sys.stdin).get('payload', {}).get('zone', 2))" 2>/dev/null || echo "2")

case $ZONE in
  1) 
    # Native Linux (unlikely for .exe but supported in theory)
    exec "$EXE_ABS" 
    ;;
  2) 
    # Try Wine first
    # [CHANGE: gemini-cli | 2026-04-25] Added Wine fallback to VM
    if wine "$EXE_ABS" 2>/dev/null; then
      notify-send "Luminos" "Running via Wine: $(basename "$EXE_ABS")"
    else
      # Wine failed — try VM
      notify-send "Luminos" "Wine failed — routing to VM"
      /usr/local/bin/luminos-vm-launch "$EXE_ABS"
    fi
    ;;
  3) 
    # Zone 3: Firecracker (Routing to Windows VM per Task 2)
    # [CHANGE: gemini-cli | 2026-04-25] Routing to VM
    notify-send "Luminos" "Running in Windows VM: $(basename "$EXE_ABS")"
    /usr/local/bin/luminos-vm-launch "$EXE_ABS"
    ;;
  4) 
    # Zone 4: KVM (Routing to Windows VM per Task 2)
    # [CHANGE: gemini-cli | 2026-04-25] Routing to VM
    notify-send "Luminos" "Running in Windows VM: $(basename "$EXE_ABS")"
    /usr/local/bin/luminos-vm-launch "$EXE_ABS"
    ;;
  *) 
    # Default: Silent fallback to Wine
    wine "$EXE_ABS"
    ;;
esac
