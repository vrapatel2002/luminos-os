{
	"log_level": "LOG_LEVEL_INFO",
	"log_subprocesses_to_journal": false,
	"dbus": {
		"enabled": true,
		"connect_timeout": "20s",
		"connect_interval": "0.200s",
		"notifications": {
			"enabled": true
		},
		"systray": {
			"enabled": true
		},
		"shortcuts": {
			"enabled": true
		},
		"brightness": {
			"enabled": true,
			"adjust_step_percent": 5,
			"min_brightness": 1,
			"enable_logind": true,
			"hud_notifications": true
		},
		"power": {
			"enabled": true,
			"low_percent": 10,
			"critical_percent": 5,
			"low_command": "",
			"critical_command": "",
			"hud_notifications": true
		}
	},
	"audio": {
		"enabled": true,
		"volume_step_percent": 5,
		"volume_exceed_maximum": false,
		"hud_notifications": true
	},
	"panels": [
		{
			"id": "panel0",
			"edge": "EDGE_BOTTOM",
			"size": 48,
			"monitor": "",
			"modules": [
				{
					"taskbar": {
						"icon_size": 28,
						"active_workspace_only": false,
						"active_monitor_only": false,
						"group_tasks": true,
						"hide_indicators": false,
						"expand": true,
						"max_size": 0,
						"pinned": [
							"luminos-launcher",
							"firefox",
							"org.kde.dolphin",
							"kitty"
						],
						"preview_width": 256,
						"minimize_on_click": true,
						"_comment": "[CHANGE: gemini-cli | 2026-04-19] Enable minimize on click"
					}
				},
				{
					"spacer": {
						"size": 8,
						"expand": false
					}
				},
				{
					"systray": {
						"icon_size": 20,
						"menu_icon_size": 20,
						"auto_hide_statuses": [
							"STATUS_UNSPECIFIED",
							"STATUS_PASSIVE",
							"STATUS_ACTIVE"
						],
						"auto_hide_delay": "4s",
						"pinned": [],
						"modules": [
							{
								"audio": {
									"icon_size": 20,
									"icon_symbolic": true,
									"command_mixer": "luminos-quick-settings-toggle",
									"enable_source": false
								}
							},
							{
								"power": {
									"icon_size": 20,
									"icon_symbolic": true
								}
							}
						]
					}
				},
				{
					"spacer": {
						"size": 4,
						"expand": false
					}
				},
				{
					"notifications": {
						"icon_size": 20,
						"notification_icon_size": 48,
						"default_timeout": "7s",
						"position": "POSITION_TOP_RIGHT",
						"margin": 12,
						"persistent": []
					}
				},
				{
					"spacer": {
						"size": 6,
						"expand": false
					}
				},
				{
					"clock": {
						"time_format": "3:04\nMon, Jan 2",
						"date_format": "",
						"tooltip_time_format": "3:04 PM",
						"tooltip_date_format": "Monday, January 2, 2006",
						"additional_regions": []
					}
				},
				{
					"spacer": {
						"size": 6,
						"expand": false
					}
				},
				{
					"session": {
						"icon_size": 20,
						"icon_symbolic": true,
						"overlay_icon_size": 64,
						"overlay_icon_symbolic": true,
						"command_logout": "loginctl terminate-session $XDG_SESSION_ID",
						"command_reboot": "systemctl reboot",
						"command_suspend": "systemctl suspend",
						"command_shutdown": "systemctl poweroff"
					}
				},
				{
					"spacer": {
						"size": 8,
						"expand": false
					}
				},
				{
					"hud": {
						"notification_icon_size": 64,
						"timeout": "2s",
						"position": "POSITION_BOTTOM",
						"margin": 64
					}
				}
			]
		}
	],
	"icon_overrides": [],
	"launch_wrapper": [
		"sh",
		"-c"
	]
