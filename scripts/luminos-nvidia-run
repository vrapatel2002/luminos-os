#!/bin/bash
# [CHANGE: claude-code | 2026-05-21] NVIDIA direct launch helper for KDE service menu
# Wakes NVIDIA from power gate then runs the app on NVIDIA PRIME
echo "on" | sudo tee /sys/bus/pci/devices/0000:01:00.0/power/control > /dev/null 2>&1 || true
sleep 0.3
export DRI_PRIME=1
export VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/nvidia_icd.json
export __EGL_VENDOR_LIBRARY_FILENAMES=/usr/share/glvnd/egl_vendor.d/60_nvidia.json
export __NV_PRIME_RENDER_OFFLOAD=1
export __GLX_VENDOR_LIBRARY_NAME=nvidia
notify-send "GPU" "Running on NVIDIA RTX 4050" --icon=dialog-information 2>/dev/null
exec "$@"
