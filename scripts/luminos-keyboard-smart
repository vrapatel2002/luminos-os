#!/bin/bash
# Luminos keyboard light — always on
# Battery no longer turns off light
# [CHANGE: gemini-cli | 2026-04-26]

BRIGHT_PATH="/sys/class/leds/asus::kbd_backlight"

# Load saved settings or use defaults
CONFIG=~/.config/luminos-keyboard.conf
if [ -f "$CONFIG" ]; then
  source "$CONFIG"
else
  KB_COLOR="ffffff"
  KB_MODE="static"
  KB_BRIGHTNESS="3"
fi

# Apply settings
asusctl aura effect $KB_MODE -c "$KB_COLOR" 2>/dev/null
echo "$KB_BRIGHTNESS" | sudo tee \
  $BRIGHT_PATH/brightness 2>/dev/null || true

# Keep running — reapply on wake from sleep
while true; do
  inotifywait -q -e modify \
    /sys/class/power_supply/ACAD/online \
    2>/dev/null || sleep 30
  asusctl aura effect $KB_MODE \
    -c "$KB_COLOR" 2>/dev/null
done
