#!/bin/bash
# HIVE Chat Popup — Bash/kdialog + llama-cli + PyQt6
# [CHANGE: antigravity | 2026-04-27]
# Launched by SUPER+SPACE via kglobalaccel → luminos-hive-popup.desktop
# 
# 
# 
# 

# ════════════════════════════════════════
# CRITICAL SECTION — DO NOT MODIFY
# KDE Wayland environment setup
# Changing this breaks SUPER+SPACE shortcut
# Last fixed: 2026-04-26 by Opus
# Touch only if KDE Plasma version changes
# ════════════════════════════════════════

# When kglobalaccel launches a process on KDE Plasma 6 Wayland,
# the child process does NOT inherit WAYLAND_DISPLAY, DISPLAY,
# DBUS_SESSION_BUS_ADDRESS, or XDG_RUNTIME_DIR. Without these,
# kdialog cannot connect to the compositor and silently exits.
# We resolve them from the user's runtime environment.

# XDG_RUNTIME_DIR — must be set first, others depend on it
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"

# WAYLAND_DISPLAY — needed for kdialog to render on Wayland
if [ -z "$WAYLAND_DISPLAY" ]; then
    # Check the most common Wayland socket names
    for sock in wayland-0 wayland-1; do
        if [ -S "$XDG_RUNTIME_DIR/$sock" ]; then
            export WAYLAND_DISPLAY="$sock"
            break
        fi
    done
fi

# DISPLAY — fallback for XWayland apps
if [ -z "$DISPLAY" ]; then
    export DISPLAY=":0"
fi

# DBUS_SESSION_BUS_ADDRESS — required for kdialog IPC
if [ -z "$DBUS_SESSION_BUS_ADDRESS" ]; then
    if [ -S "$XDG_RUNTIME_DIR/bus" ]; then
        export DBUS_SESSION_BUS_ADDRESS="unix:path=$XDG_RUNTIME_DIR/bus"
    else
        export DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$(id -u)/bus"
    fi
fi

# XDG_SESSION_TYPE — tells Qt/kdialog to use Wayland backend
export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"

# QT_QPA_PLATFORM — force kdialog to use wayland
export QT_QPA_PLATFORM="${QT_QPA_PLATFORM:-wayland}"

# HOME — sometimes missing in service contexts
export HOME="${HOME:-$(getent passwd $(id -u) | cut -d: -f6)}"

# ════════════════════════════════════════
# END CRITICAL SECTION
# ════════════════════════════════════════

LOCKFILE="/tmp/luminos-hive-popup.lock"

if [ -f "$LOCKFILE" ]; then
    OLD_PID=$(cat "$LOCKFILE")
    if kill -0 "$OLD_PID" 2>/dev/null; then
        kill -TERM "$OLD_PID"
        exit 0
    fi
fi

echo $$ > "$LOCKFILE"
trap "rm -f $LOCKFILE" EXIT

# HiDPI scale factor if needed (can be uncommented if too small)
# export QT_SCALE_FACTOR=2


# Auto-start Nexus if llama-server not running
if ! pgrep -x "llama-server" > /dev/null; then
    /home/shawn/luminos-os/scripts/hive-start-model.sh nexus &
    sleep 8  # wait for model to load into VRAM
fi

# Keep watchdog alive while popup is open
(
    while kill -0 $$ 2>/dev/null; do
        touch /tmp/hive-last-request
        sleep 30
    done
) &

exec qml6 ~/luminos-os/src/hive/HiveChat.qml
