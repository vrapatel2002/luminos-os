#!/bin/bash
# HIVE Chat Popup — Bash/kdialog + llama-cli + PyQt6
# [CHANGE: antigravity | 2026-04-27]
# Launched by SUPER+SPACE via kglobalaccel → luminos-hive-popup.desktop
# 
# 
# 
# 

# ════════════════════════════════════════
# CRITICAL SECTION — DO NOT MODIFY
# KDE Wayland environment setup
# Changing this breaks SUPER+SPACE shortcut
# Last fixed: 2026-04-26 by Opus
# Touch only if KDE Plasma version changes
# ════════════════════════════════════════

# When kglobalaccel launches a process on KDE Plasma 6 Wayland,
# the child process does NOT inherit WAYLAND_DISPLAY, DISPLAY,
# DBUS_SESSION_BUS_ADDRESS, or XDG_RUNTIME_DIR. Without these,
# kdialog cannot connect to the compositor and silently exits.
# We resolve them from the user's runtime environment.

# XDG_RUNTIME_DIR — must be set first, others depend on it
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"

# WAYLAND_DISPLAY — needed for kdialog to render on Wayland
if [ -z "$WAYLAND_DISPLAY" ]; then
    # Check the most common Wayland socket names
    for sock in wayland-0 wayland-1; do
        if [ -S "$XDG_RUNTIME_DIR/$sock" ]; then
            export WAYLAND_DISPLAY="$sock"
            break
        fi
    done
fi

# DISPLAY — fallback for XWayland apps
if [ -z "$DISPLAY" ]; then
    export DISPLAY=":0"
fi

# DBUS_SESSION_BUS_ADDRESS — required for kdialog IPC
if [ -z "$DBUS_SESSION_BUS_ADDRESS" ]; then
    if [ -S "$XDG_RUNTIME_DIR/bus" ]; then
        export DBUS_SESSION_BUS_ADDRESS="unix:path=$XDG_RUNTIME_DIR/bus"
    else
        export DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$(id -u)/bus"
    fi
fi

# XDG_SESSION_TYPE — tells Qt/kdialog to use Wayland backend
export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"

# QT_QPA_PLATFORM — force kdialog to use wayland
export QT_QPA_PLATFORM="${QT_QPA_PLATFORM:-wayland}"

# HOME — sometimes missing in service contexts
export HOME="${HOME:-$(getent passwd $(id -u) | cut -d: -f6)}"

# ════════════════════════════════════════
# END CRITICAL SECTION
# ════════════════════════════════════════

# ════════════════════════════════════════
# MODEL PATHS — Update here when changing models
# Safe to modify this section only
# ════════════════════════════════════════

MODEL_PATH="$HOME/.local/share/luminos/models/hive/Dolphin3.0-Llama3.1-8B-Q4_K_M.gguf"
LLAMA_CLI="/usr/local/bin/llama-cli"

# ════════════════════════════════════════
# END MODEL PATHS
# ════════════════════════════════════════

export MODEL_PATH LLAMA_CLI

if python3 -c "import PyQt6" 2>/dev/null; then
    python3 - << 'EOF'
import sys
import os
import subprocess
import time
from PyQt6.QtWidgets import (QApplication, QMainWindow, QWidget, QVBoxLayout, 
                             QHBoxLayout, QTextEdit, QLineEdit, QPushButton, QLabel,
                             QFrame, QSizePolicy)
from PyQt6.QtCore import Qt, QThread, pyqtSignal

MODEL_PATH = os.environ.get("MODEL_PATH", "")
LLAMA_CLI = os.environ.get("LLAMA_CLI", "")

# Theme Variables matching gemini-code-1777263963106.html
BG_SIDEBAR = "#1e1e1e"
BG_MAIN = "#252525"
BG_INPUT = "#333333"
BG_HOVER = "#2c2c2c"
TEXT_PRIMARY = "#ececec"
TEXT_SECONDARY = "#9e9e9e"
TEXT_ACCENT = "#c48b71"
BORDER_COLOR = "#424242"
FONT_FAMILY = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif'

class InferenceThread(QThread):
    response_ready = pyqtSignal(str, float)
    error_occurred = pyqtSignal(str)

    def __init__(self, prompt, history):
        super().__init__()
        self.prompt = prompt
        self.history = history

    def run(self):
        try:
            start_time = time.time()
            
            formatted_prompt = "<|begin_of_text|><|start_header_id|>system<|end_header_id|>\n\nYou are HIVE, the Luminos OS AI assistant. You are helpful, concise, and knowledgeable about Linux systems.<|eot_id|>"
            
            for h_prompt, h_resp in self.history:
                formatted_prompt += f"<|start_header_id|>user<|end_header_id|>\n\n{h_prompt}<|eot_id|><|start_header_id|>assistant<|end_header_id|>\n\n{h_resp}<|eot_id|>"
                
            formatted_prompt += f"<|start_header_id|>user<|end_header_id|>\n\n{self.prompt}<|eot_id|><|start_header_id|>assistant<|end_header_id|>\n\n"

            cmd = [
                LLAMA_CLI,
                "-m", MODEL_PATH,
                "-p", formatted_prompt,
                "-n", "512",
                "--temp", "0.7",
                "-ngl", "99",
                "--log-disable",
                "--no-display-prompt",
                "-no-cnv"
            ]
            
            process = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
            stdout, stderr = process.communicate()
            
            if process.returncode != 0:
                self.error_occurred.emit(f"Error: {stderr.strip()}")
                return
                
            elapsed = time.time() - start_time
            self.response_ready.emit(stdout.strip(), elapsed)
            
        except Exception as e:
            self.error_occurred.emit(str(e))

class ChatWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self.history = []
        self.initUI()
        
    def initUI(self):
        self.setWindowTitle('HIVE — Luminos AI')
        self.resize(1000, 700)
        self.setStyleSheet(f"background-color: {BG_MAIN}; color: {TEXT_PRIMARY}; font-family: {FONT_FAMILY};")
        
        central_widget = QWidget()
        self.setCentralWidget(central_widget)
        main_layout = QHBoxLayout(central_widget)
        main_layout.setContentsMargins(0, 0, 0, 0)
        main_layout.setSpacing(0)
        
        # --- Sidebar ---
        sidebar = QFrame()
        sidebar.setFixedWidth(260)
        sidebar.setStyleSheet(f"""
            QFrame {{
                background-color: {BG_SIDEBAR};
                border-right: 1px solid {BORDER_COLOR};
            }}
        """)
        sidebar_layout = QVBoxLayout(sidebar)
        sidebar_layout.setContentsMargins(16, 16, 16, 16)
        sidebar_layout.setAlignment(Qt.AlignmentFlag.AlignTop)
        
        sidebar_header = QLabel("Claude")
        sidebar_header.setStyleSheet(f"font-size: 1.2rem; font-weight: 600; color: {TEXT_PRIMARY}; border: none;")
        sidebar_layout.addWidget(sidebar_header)
        sidebar_layout.addSpacing(20)
        
        nav_items = ["+ New chat", "🔍 Search", "💬 Chats", "📁 Projects", "</> Code", "⚙ Customize", "✨ Design"]
        for item in nav_items:
            btn = QPushButton(item)
            btn.setStyleSheet(f"""
                QPushButton {{
                    background-color: transparent;
                    color: {TEXT_PRIMARY};
                    text-align: left;
                    padding: 8px 12px;
                    border-radius: 6px;
                    border: none;
                    font-size: 0.9rem;
                }}
                QPushButton:hover {{
                    background-color: {BG_HOVER};
                }}
            """)
            btn.setCursor(Qt.CursorShape.PointingHandCursor)
            sidebar_layout.addWidget(btn)
            
        sidebar_layout.addSpacing(20)
        
        starred_lbl = QLabel("STARRED")
        starred_lbl.setStyleSheet(f"color: {TEXT_SECONDARY}; font-size: 0.75rem; border: none; padding-left: 12px; letter-spacing: 0.05em;")
        sidebar_layout.addWidget(starred_lbl)
        sidebar_layout.addSpacing(10)
        
        history_items = ["Reviewing recent conversation h...", "Reviving forex trading bot project", "Login screen and boot issues de..."]
        for item in history_items:
            btn = QPushButton(item)
            btn.setStyleSheet(f"""
                QPushButton {{
                    background-color: transparent;
                    color: {TEXT_SECONDARY};
                    text-align: left;
                    padding: 8px 12px;
                    border-radius: 6px;
                    border: none;
                    font-size: 0.85rem;
                }}
                QPushButton:hover {{
                    background-color: {BG_HOVER};
                    color: {TEXT_PRIMARY};
                }}
            """)
            btn.setCursor(Qt.CursorShape.PointingHandCursor)
            sidebar_layout.addWidget(btn)
            
        main_layout.addWidget(sidebar)
        
        # --- Main Content Area ---
        content_area = QWidget()
        content_layout = QVBoxLayout(content_area)
        content_layout.setContentsMargins(0, 0, 0, 0)
        content_layout.setSpacing(0)
        
        top_nav = QFrame()
        top_nav.setFixedHeight(64)
        top_nav.setStyleSheet("border: none;")
        content_layout.addWidget(top_nav)
        
        self.chat_display = QTextEdit()
        self.chat_display.setReadOnly(True)
        self.chat_display.setStyleSheet(f"""
            QTextEdit {{
                background-color: transparent;
                border: none;
                padding: 20px;
                font-size: 1rem;
                color: {TEXT_PRIMARY};
            }}
        """)
        
        self.chat_display.append(f"<div style='font-family: Georgia, serif; font-size: 2.5rem; text-align: center; margin-top: 50px; margin-bottom: 30px;'><span style='color: {TEXT_ACCENT};'>✺</span> Hello, night owl</div>")
        
        content_layout.addWidget(self.chat_display)
        
        input_container = QWidget()
        input_container_layout = QVBoxLayout(input_container)
        input_container_layout.setContentsMargins(40, 20, 40, 30)
        
        self.input_wrapper = QFrame()
        self.input_wrapper.setMaximumWidth(800)
        self.input_wrapper.setStyleSheet(f"""
            QFrame {{
                background-color: {BG_INPUT};
                border: 1px solid {BORDER_COLOR};
                border-radius: 16px;
            }}
        """)
        
        wrapper_layout = QVBoxLayout(self.input_wrapper)
        wrapper_layout.setContentsMargins(16, 12, 16, 12)
        wrapper_layout.setSpacing(10)
        
        input_top_layout = QHBoxLayout()
        input_top_layout.setContentsMargins(0,0,0,0)
        
        add_btn = QLabel("+")
        add_btn.setStyleSheet(f"color: {TEXT_SECONDARY}; font-size: 1.5rem; border: none;")
        input_top_layout.addWidget(add_btn)
        
        self.input_field = QLineEdit()
        self.input_field.setPlaceholderText("How can I help you today?")
        self.input_field.setStyleSheet(f"""
            QLineEdit {{
                background-color: transparent;
                border: none;
                color: {TEXT_PRIMARY};
                font-size: 1rem;
            }}
        """)
        self.input_field.returnPressed.connect(self.send_message)
        input_top_layout.addWidget(self.input_field)
        
        wrapper_layout.addLayout(input_top_layout)
        
        input_controls_layout = QHBoxLayout()
        input_controls_layout.setContentsMargins(0,0,0,0)
        
        model_name = "Unknown"
        if "dolphin" in MODEL_PATH.lower():
            model_name = "Nexus"
        elif "qwen" in MODEL_PATH.lower():
            model_name = "Bolt"
        elif "deepseek" in MODEL_PATH.lower():
            model_name = "Nova"
            
        self.model_label = model_name
        
        model_lbl = QLabel(f"{model_name} Adaptive ⌄")
        model_lbl.setStyleSheet(f"color: {TEXT_SECONDARY}; font-size: 0.85rem; border: none;")
        input_controls_layout.addWidget(model_lbl)
        
        input_controls_layout.addStretch()
        
        self.send_button = QPushButton("➤")
        self.send_button.setCursor(Qt.CursorShape.PointingHandCursor)
        self.send_button.setStyleSheet(f"""
            QPushButton {{
                background-color: transparent;
                color: {TEXT_SECONDARY};
                border: none;
                font-size: 1.2rem;
            }}
            QPushButton:hover {{
                color: {TEXT_PRIMARY};
            }}
        """)
        self.send_button.clicked.connect(self.send_message)
        input_controls_layout.addWidget(self.send_button)
        
        wrapper_layout.addLayout(input_controls_layout)
        
        h_layout = QHBoxLayout()
        h_layout.addStretch()
        h_layout.addWidget(self.input_wrapper)
        h_layout.addStretch()
        
        input_container_layout.addLayout(h_layout)
        content_layout.addWidget(input_container)
        
        main_layout.addWidget(content_area)
        
    def keyPressEvent(self, event):
        if event.key() == Qt.Key.Key_Escape:
            self.close()
            
    def append_user_message(self, text):
        self.chat_display.append(f"<div style='margin-top: 20px; max-width: 800px; margin-left: auto; margin-right: auto;'><div style='color: {TEXT_PRIMARY}; font-size: 1.1rem;'>{text}</div></div>")
        
    def append_hive_message(self, text, elapsed=None):
        header = f"<div style='color: {TEXT_SECONDARY}; font-size: 0.9rem; margin-bottom: 8px;'><span style='color: {TEXT_ACCENT};'>✺</span> HIVE ({self.model_label})"
        if elapsed is not None:
            header += f" — {elapsed:.1f}s"
        header += "</div>"
            
        self.chat_display.append(f"<div style='margin-top: 20px; max-width: 800px; margin-left: auto; margin-right: auto;'>{header}")
        
        formatted_text = text.replace('\\n', '<br>')
        self.chat_display.append(f"<div style='color: {TEXT_PRIMARY}; line-height: 1.5; font-size: 1rem;'>{formatted_text}</div></div><br>")
        
        scrollbar = self.chat_display.verticalScrollBar()
        scrollbar.setValue(scrollbar.maximum())
        
    def send_message(self):
        prompt = self.input_field.text().strip()
        if not prompt:
            return
            
        if not self.history:
            self.chat_display.clear() # clear greeting
            
        self.input_field.clear()
        self.input_field.setEnabled(False)
        self.send_button.setEnabled(False)
        
        self.append_user_message(prompt)
        
        self.thread = InferenceThread(prompt, self.history)
        self.thread.response_ready.connect(lambda resp, elap: self.on_response(prompt, resp, elap))
        self.thread.error_occurred.connect(self.on_error)
        self.thread.start()
        
    def on_response(self, prompt, response, elapsed):
        self.history.append((prompt, response))
        self.append_hive_message(response, elapsed)
        self.input_field.setEnabled(True)
        self.send_button.setEnabled(True)
        self.input_field.setFocus()
        
    def on_error(self, error_msg):
        self.chat_display.append(f"<div style='color: #FF5555; margin-top: 10px; margin-bottom: 10px; max-width: 800px; margin-left: auto; margin-right: auto;'><b>Error:</b> {error_msg}</div><br>")
        self.input_field.setEnabled(True)
        self.send_button.setEnabled(True)
        self.input_field.setFocus()

if __name__ == '__main__':
    app = QApplication(sys.argv)
    ex = ChatWindow()
    ex.show()
    sys.exit(app.exec())
EOF
else
    # Fallback to kdialog conversation loop if PyQt6 is not installed
    HISTORY=""
    while true; do
        if [ -z "$HISTORY" ]; then
            TEXT="Ask HIVE:"
        else
            TEXT="$HISTORY\n\nAsk HIVE:"
        fi
        
        USER_PROMPT=$(kdialog --title "HIVE — Luminos AI" --inputbox "$TEXT")
        if [ $? -ne 0 ] || [ -z "$USER_PROMPT" ]; then
            break
        fi
        
        kdialog --passivepopup "HIVE is thinking..." 3
        
        FORMATTED_PROMPT="<|begin_of_text|><|start_header_id|>system<|end_header_id|>\n\nYou are HIVE, the Luminos OS AI assistant.<|eot_id|><|start_header_id|>user<|end_header_id|>\n\n${USER_PROMPT}<|eot_id|><|start_header_id|>assistant<|end_header_id|>\n\n"
        
        RESPONSE=$("$LLAMA_CLI" -m "$MODEL_PATH" -p "$FORMATTED_PROMPT" -n 512 --temp 0.7 -ngl 99 --log-disable --no-display-prompt -no-cnv 2>/dev/null)
        
        HISTORY="${HISTORY}\nYou: ${USER_PROMPT}\nHIVE: ${RESPONSE}\n----------------"
    done
fi
