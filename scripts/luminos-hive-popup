#!/usr/bin/env python3
# HIVE Proper Chat UI — GTK4 based
# [CHANGE: gemini-cli | 2026-04-26]

import os
import sys
import json
import threading
import gi

gi.require_version('Gtk', '4.0')
gi.require_version('Adw', '1')
from gi.repository import Gtk, Gdk, GLib, Adw

# Add src to path for orchestrator
sys.path.insert(0, '/home/shawn/luminos-os/src')

class HiveChatWindow(Adw.ApplicationWindow):
    def __init__(self, **kwargs):
        super().__init__(**kwargs)

        self.set_title("HIVE — Luminos AI")
        self.set_default_size(600, 450)
        self.set_resizable(True)

        # Style context for dark theme and custom colors
        style_provider = Gtk.CssProvider()
        style_provider.load_from_data(b"""
            window {
                background-color: #0A0A0F;
                color: white;
            }
            .chat-box {
                background-color: #12121A;
                border-radius: 10px;
                padding: 10px;
                margin: 5px;
            }
            .user-msg {
                color: #0080FF;
                font-weight: bold;
            }
            .hive-msg {
                color: #FFFFFF;
            }
            .input-box {
                background-color: #1A1A24;
                color: white;
                border: 1px solid #333;
                border-radius: 5px;
                padding: 5px;
            }
        """)
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(),
            style_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )

        # Main Layout
        self.main_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self.set_content(self.main_box)

        # Chat History Area
        self.scroll = Gtk.ScrolledWindow()
        self.scroll.set_vexpand(True)
        self.main_box.append(self.scroll)

        self.chat_view = Gtk.TextView()
        self.chat_view.set_editable(False)
        self.chat_view.set_cursor_visible(False)
        self.chat_view.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
        self.chat_view.add_css_class("chat-box")
        self.scroll.set_child(self.chat_view)
        self.buffer = self.chat_view.get_buffer()

        # Input Area
        self.entry_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        self.entry_box.set_margin_start(10)
        self.entry_box.set_margin_end(10)
        self.entry_box.set_margin_top(10)
        self.entry_box.set_margin_bottom(10)
        self.main_box.append(self.entry_box)

        self.entry = Gtk.Entry()
        self.entry.set_placeholder_text("Ask HIVE...")
        self.entry.set_hexpand(True)
        self.entry.add_css_class("input-box")
        self.entry.connect("activate", self.on_send_clicked)
        self.entry_box.append(self.entry)

        self.send_btn = Gtk.Button(label="Send")
        self.send_btn.connect("clicked", self.on_send_clicked)
        self.entry_box.append(self.send_btn)

        # Shortcuts
        self.controller = Gtk.EventControllerKey()
        self.controller.connect("key-pressed", self.on_key_pressed)
        self.add_controller(self.controller)

        # Initialize HIVE
        self.append_text("System", "HIVE connected and ready.")
        
        # Auto-focus entry
        self.entry.grab_focus()

    def append_text(self, sender, text):
        end_iter = self.buffer.get_end_iter()
        tag = "user-msg" if sender == "User" else "hive-msg"
        
        # Create tag if it doesn't exist
        if not self.buffer.get_tag_table().lookup(tag):
            if tag == "user-msg":
                self.buffer.create_tag(tag, foreground="#0080FF", weight=700)
            else:
                self.buffer.create_tag(tag, foreground="#FFFFFF")

        self.buffer.insert_with_tags_by_name(end_iter, f"\n{sender}: ", tag)
        self.buffer.insert(self.buffer.get_end_iter(), f"{text}\n")
        
        # Scroll to bottom
        adj = self.scroll.get_vadjustment()
        adj.set_value(adj.get_upper() - adj.get_page_size())

    def on_send_clicked(self, widget):
        text = self.entry.get_text().strip()
        if not text:
            return
        
        self.entry.set_text("")
        self.append_text("User", text)
        self.send_btn.set_sensitive(False)
        self.entry.set_sensitive(False)

        threading.Thread(target=self.call_hive, args=(text,), daemon=True).start()

    def call_hive(self, prompt):
        try:
            from hive.orchestrator import HIVEOrchestrator
            hive = HIVEOrchestrator()
            result = hive.chat(prompt)
            GLib.idle_add(self.show_response, result)
        except Exception as e:
            GLib.idle_add(self.append_text, "Error", str(e))
            GLib.idle_add(self.send_btn.set_sensitive, True)
            GLib.idle_add(self.entry.set_sensitive, True)

    def show_response(self, result):
        model = result.get('model_used', 'unknown')
        tps = result.get('tokens_per_sec', 0)
        self.append_text(f"HIVE ({model} | {tps} t/s)", result.get('response', ''))
        self.send_btn.set_sensitive(True)
        self.entry.set_sensitive(True)
        self.entry.grab_focus()

    def on_key_pressed(self, controller, keyval, keycode, state):
        if keyval == Gdk.KEY_Escape:
            self.close()
            return True
        return False

class HiveApp(Adw.Application):
    def __init__(self, **kwargs):
        super().__init__(application_id='org.luminos.hive-chat', **kwargs)

    def do_activate(self):
        win = self.active_window
        if not win:
            win = HiveChatWindow(application=self)
        win.present()

if __name__ == "__main__":
    app = HiveApp()
    app.run(sys.argv)
