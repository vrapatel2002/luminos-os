#!/bin/bash
# HIVE Chat Popup — Bash/kdialog + llama-cli + PyQt6
# [CHANGE: antigravity | 2026-04-27]
# Launched by SUPER+SPACE via kglobalaccel → luminos-hive-popup.desktop
# 
# 
# 
# 

# ════════════════════════════════════════
# CRITICAL SECTION — DO NOT MODIFY
# KDE Wayland environment setup
# Changing this breaks SUPER+SPACE shortcut
# Last fixed: 2026-04-26 by Opus
# Touch only if KDE Plasma version changes
# ════════════════════════════════════════

# When kglobalaccel launches a process on KDE Plasma 6 Wayland,
# the child process does NOT inherit WAYLAND_DISPLAY, DISPLAY,
# DBUS_SESSION_BUS_ADDRESS, or XDG_RUNTIME_DIR. Without these,
# kdialog cannot connect to the compositor and silently exits.
# We resolve them from the user's runtime environment.

# XDG_RUNTIME_DIR — must be set first, others depend on it
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"

# WAYLAND_DISPLAY — needed for kdialog to render on Wayland
if [ -z "$WAYLAND_DISPLAY" ]; then
    # Check the most common Wayland socket names
    for sock in wayland-0 wayland-1; do
        if [ -S "$XDG_RUNTIME_DIR/$sock" ]; then
            export WAYLAND_DISPLAY="$sock"
            break
        fi
    done
fi

# DISPLAY — fallback for XWayland apps
if [ -z "$DISPLAY" ]; then
    export DISPLAY=":0"
fi

# DBUS_SESSION_BUS_ADDRESS — required for kdialog IPC
if [ -z "$DBUS_SESSION_BUS_ADDRESS" ]; then
    if [ -S "$XDG_RUNTIME_DIR/bus" ]; then
        export DBUS_SESSION_BUS_ADDRESS="unix:path=$XDG_RUNTIME_DIR/bus"
    else
        export DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$(id -u)/bus"
    fi
fi

# XDG_SESSION_TYPE — tells Qt/kdialog to use Wayland backend
export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"

# QT_QPA_PLATFORM — force Qt to use wayland
export QT_QPA_PLATFORM="${QT_QPA_PLATFORM:-wayland}"

# [CHANGE: gemini-cli | 2026-04-27] Allow QML to read /tmp/hive-active-model
export QML_XHR_ALLOW_FILE_READ=1

# HOME — sometimes missing in service contexts
export HOME="${HOME:-$(/usr/bin/getent passwd $(/usr/bin/id -u) | /usr/bin/cut -d: -f6)}"

# ════════════════════════════════════════
# END CRITICAL SECTION
# ════════════════════════════════════════

# ════════════════════════════════════════
# SECTION: Hardened Environment for KDE Shortcut Launch
# PURPOSE: kglobalaccel launches with a MINIMAL env — PATH, HOME,
#          LD_LIBRARY_PATH, CUDA vars are all missing or incomplete.
#          We export everything explicitly so llama-server, pgrep,
#          curl, and qml6 all work from the shortcut context.
# [CHANGE: antigravity | 2026-04-28]
# ════════════════════════════════════════

export PATH="/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/opt/cuda/bin:$PATH"
export LD_LIBRARY_PATH="/opt/cuda/lib64:/usr/lib:/usr/local/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
export CUDA_VISIBLE_DEVICES="${CUDA_VISIBLE_DEVICES:-0}"

# ════════════════════════════════════════
# SECTION: Toggle Lock (SUPER+SPACE on/off)
# PURPOSE: If popup is already open, close it. Otherwise start new.
# ════════════════════════════════════════

LOCKFILE="/tmp/luminos-hive-popup.lock"

if [ -f "$LOCKFILE" ]; then
    OLD_PID=$(/usr/bin/cat "$LOCKFILE" 2>/dev/null)
    if [ -n "$OLD_PID" ] && /usr/bin/kill -0 "$OLD_PID" 2>/dev/null; then
        /usr/bin/kill -TERM "$OLD_PID"
        exit 0
    fi
fi

echo $$ > "$LOCKFILE"
trap "/usr/bin/rm -f $LOCKFILE; /usr/bin/pkill -f 'hive-swap-server.py' 2>/dev/null; kill \$SWAP_PID 2>/dev/null; kill \$LLAMA_START_PID 2>/dev/null" EXIT

# ════════════════════════════════════════
# SECTION: Auto-start Nexus
# PURPOSE: If llama-server isn't running, start it before the UI.
#          Uses nohup + disown so the server survives independently.
#          Non-blocking: removed sleep 8.
# [CHANGE: gemini-cli | 2026-04-28]
# ════════════════════════════════════════

LLAMA_START_PID=""
if ! /usr/bin/pgrep -x "llama-server" > /dev/null 2>&1; then
    echo "[LAUNCHER] llama-server not running, starting..."
    bash /home/shawn/luminos-os/scripts/hive-start-model.sh nexus >> /tmp/hive-server.log 2>&1 &
    LLAMA_START_PID=$!
    echo "nexus" > /tmp/hive-active-model
else
    # Server is already running, try to detect which model is active
    /usr/bin/pgrep -a "llama-server" | /usr/bin/grep -oP "(?<=--model-name\s)\w+" > /tmp/hive-active-model 2>/dev/null
    if [ ! -s /tmp/hive-active-model ]; then
        echo "nexus" > /tmp/hive-active-model
    fi
fi

# Mark activity so idle-watchdog doesn't kill while popup is open
/usr/bin/touch /tmp/hive-last-request

# [CHANGE: antigravity | 2026-04-28] Start swap server if not running
SWAP_PID=""
if ! /usr/bin/pgrep -f "hive-swap-server.py" > /dev/null 2>&1; then
    echo "[LAUNCHER] swap server not running, starting..."
    /usr/bin/python3 /home/shawn/luminos-os/scripts/hive-swap-server.py &
    SWAP_PID=$!
fi

# ════════════════════════════════════════
# SECTION: Watchdog Keep-Alive Loop
# PURPOSE: Touch the activity marker every 30s while popup is open
#          so the idle-watchdog doesn't kill llama-server under us.
#          Killed automatically when qml6 exits (via wait + trap).
# ════════════════════════════════════════

KEEP_ALIVE_PID=""
(
    while /usr/bin/kill -0 $$ 2>/dev/null; do
        /usr/bin/touch /tmp/hive-last-request
        /usr/bin/sleep 30
    done
) &
KEEP_ALIVE_PID=$!

# ════════════════════════════════════════
# SECTION: Launch QML UI
# PURPOSE: Run qml6 in foreground (NOT exec) so this bash process
#          stays alive to manage the keep-alive loop and lockfile.
# ════════════════════════════════════════

/usr/bin/qml6 /home/shawn/luminos-os/src/hive/HiveChat.qml

# Cleanup: kill keep-alive loop and swap server after popup closes
if [ -n "$KEEP_ALIVE_PID" ]; then
    /usr/bin/kill "$KEEP_ALIVE_PID" 2>/dev/null
    wait "$KEEP_ALIVE_PID" 2>/dev/null
fi
# [CHANGE: antigravity | 2026-04-28] Kill swap server on popup close
if [ -n "$SWAP_PID" ]; then
    /usr/bin/kill "$SWAP_PID" 2>/dev/null
    wait "$SWAP_PID" 2>/dev/null
fi
