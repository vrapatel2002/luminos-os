#!/bin/bash
# HIVE Proper Chat UI — kdialog based
# [CHANGE: antigravity | 2026-04-26]

# Get user input
USER_PROMPT=$(kdialog --title "HIVE — Luminos AI" --inputbox "Ask HIVE:")
if [ $? -ne 0 ] || [ -z "$USER_PROMPT" ]; then
    exit 0
fi

# Notify user
kdialog --passivepopup "HIVE is thinking..." 3

# Find model
MODEL_PATH="$HOME/.local/share/luminos/models/hive/Dolphin3.0-Llama3.1-8B-Q4_K_M.gguf"

# Format prompt
FORMATTED_PROMPT="<|begin_of_text|><|start_header_id|>system<|end_header_id|>

You are HIVE, the Luminos OS AI assistant.<|eot_id|><|start_header_id|>user<|end_header_id|>

${USER_PROMPT}<|eot_id|><|start_header_id|>assistant<|end_header_id|>

"

# Run inference
RESPONSE=$(/usr/local/bin/llama-cli -m "$MODEL_PATH" \
    -p "$FORMATTED_PROMPT" \
    -n 512 \
    --temp 0.7 \
    --log-disable \
    --no-display-prompt \
    -no-cnv 2>/dev/null)

# Show response
kdialog --title "HIVE" --msgbox "$RESPONSE"
