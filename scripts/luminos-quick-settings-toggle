#!/usr/bin/env bash
# Luminos Quick Settings — Go GTK4 layer-shell quick control panel
# Toggle via: Super+S keybind or systray click
# Uses USR1 signal to toggle an already-running panel instance

PIDFILE="/tmp/luminos-quick-settings.pid"

# If panel is already running, send toggle signal
if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    kill -USR1 "$(cat "$PIDFILE")"
    exit 0
fi

# Launch the Go quick settings binary
exec luminos-quick-settings-go
