#!/bin/bash
# [CHANGE: claude-code | 2026-05-21] Quick display Hz toggle — 120Hz (performance)
WAYLAND_DISPLAY=wayland-0 DBUS_SESSION_BUS_ADDRESS="$(cat /run/user/1000/dbus-session)" kscreen-doctor output.1.mode.2880x1800@120 2>/dev/null || \
  python3 -c "
import json, subprocess
cfg = json.load(open('/home/shawn/.config/kwinoutputconfig.json'))
for item in cfg:
    for o in item.get('data', []):
        if 'mode' in o:
            o['mode']['refreshRate'] = 120000
json.dump(cfg, open('/home/shawn/.config/kwinoutputconfig.json', 'w'), indent=4)
" && WAYLAND_DISPLAY=wayland-0 qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null
notify-send "Display" "120 Hz — Performance mode" --icon=video-display 2>/dev/null
