#!/usr/bin/env python3
"""
scripts/luminos-launcher-toggle
Toggle the Luminos app launcher via direct import or D-Bus fallback.
Called from Hyprland keybinding: Super key.
"""

import os
import sys

SRC = os.path.join(os.path.dirname(os.path.abspath(__file__)), "..", "src")
if SRC not in sys.path:
    sys.path.insert(0, SRC)

try:
    from gui.launcher import toggle_launcher
    toggle_launcher()
except Exception as e:
    # Fallback: send signal to running bar process
    import subprocess
    subprocess.run(
        ["dbus-send", "--session", "--type=method_call",
         "--dest=io.luminos.bar", "/io/luminos/bar",
         "io.luminos.bar.ToggleLauncher"],
        capture_output=True, timeout=3,
    )
